# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: edge-tts voice (free, no API key needed — uses Microsoft Edge TTS)
# Default is British male voice, perfect for JARVIS.
# Other options: en-GB-SoniaNeural (British female), en-US-GuyNeural (American male)
# Full list: run `edge-tts --list-voices` in terminal
# EDGE_TTS_VOICE=en-GB-RyanNeural

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com
